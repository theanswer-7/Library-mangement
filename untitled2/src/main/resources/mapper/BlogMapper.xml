<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- 这里必须是你的dao路径 -->
<mapper namespace="com.it.dao.BlogMapper">

    <!-- 博客基础映射 -->
    <resultMap id="BlogMap" type="com.it.pojo.Blog">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="author" property="author"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <!-- 评论基础映射 -->
    <resultMap id="CommentMap" type="com.it.pojo.Comment">
        <id column="cid" property="id"/>
        <result column="blog_id" property="blogId"/>
        <result column="ccontent" property="content"/>
        <result column="commentator" property="commentator"/>
        <result column="comment_time" property="commentTime"/>
    </resultMap>

    <!-- 方式一：嵌套结果映射 -->
    <resultMap id="BlogWithCommentResultMap" type="com.it.pojo.Blog" extends="BlogMap">
        <collection property="commentList" ofType="com.it.pojo.Comment" resultMap="CommentMap"/>
    </resultMap>

    <select id="getBlogWithCommentByResult" resultMap="BlogWithCommentResultMap">
        SELECT b.id,b.title,b.content,b.author,b.create_time,
               c.id cid,c.blog_id,c.content ccontent,c.commentator,c.comment_time
        FROM t_blog b
                 LEFT JOIN t_comment c ON b.id = c.blog_id
        WHERE b.id = #{bid}
    </select>

    <!-- 方式二：嵌套查询 -->
    <select id="findCommentByBlogId" resultMap="CommentMap">
        SELECT id cid,blog_id,content ccontent,commentator,comment_time
        FROM t_comment WHERE blog_id = #{bid}
    </select>

    <resultMap id="BlogWithCommentSelectMap" type="com.it.pojo.Blog" extends="BlogMap">
        <collection property="commentList"
                    select="com.it.dao.BlogMapper.findCommentByBlogId"
                    column="id"/>
    </resultMap>

    <select id="getBlogWithCommentBySelect" resultMap="BlogWithCommentSelectMap">
        SELECT id,title,content,author,create_time
        FROM t_blog WHERE id = #{bid}
    </select>

</mapper>