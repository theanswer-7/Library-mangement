<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.it.dao.OrdersMapper">

    <!-- 定义订单结果映射，包含商品列表 -->
    <resultMap id="OrderWithProductMap" type="com.it.pojo.Orders">
        <id column="orders_id" property="id"/>
        <result column="number" property="number"/>
        <!-- 一对多：订单包含多个商品 -->
        <collection property="productList" ofType="com.it.pojo.Product">
            <id column="product_id" property="id"/>
            <result column="name" property="name"/>
            <result column="price" property="price"/>
        </collection>
    </resultMap>

    <!-- 根据订单id查询订单及商品信息 -->
    <select id="findOrderWithProducts" resultMap="OrderWithProductMap">
        SELECT
            o.id AS orders_id,
            o.number,
            p.id AS product_id,
            p.name,
            p.price
        FROM
            tb_orders o
                JOIN tb_product_orders po ON o.id = po.orders_id
                JOIN tb_product p ON po.product_id = p.id
        WHERE
            o.id = #{orderId}
    </select>

</mapper>